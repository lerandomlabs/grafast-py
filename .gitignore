# Python bytecode + tool caches only. Everything else (reference/, tests/,
# gtests/, bench/, notes/, SUMMARY.md, PRODUCTION_PLAN.md, AGENTS.md, demo_plan.py,
# uv.lock, *.md reports) is intentionally NOT ignored — it stays untracked and
# visible in `git status` so we can decide per-item what belongs in the public repo.
# Fetched by scripts/fetch_conformance.py — the third-party graphql-core test
# suite is downloaded on demand, never committed. The committed conformance/
# package shell (__init__.py + conftest.py) drives it; only the fetched suite is
# ignored.
/conformance/_suite/

# differential suite (tests/differential/): generated artifacts + Node deps
/tests/differential/node/node_modules/
/tests/differential/node/out/
/tests/differential/out/

__pycache__/
*.py[cod]
*.swp
.venv/
.ruff_cache/
.pytest_cache/
.benchmarks/
